generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── PRODUTOS ────────────────────────────────────────────────
model Produto {
  id                  String     @id @default(cuid())
  skuPrincipal        String     @unique
  nome                String
  categoria           String     @default("Geral")
  unidadeCompra       String     @default("kg")
  custoPorKg          Float?
  custoUnitario       Float?
  custoAtualizado     Float?
  dataUltimaCompra    DateTime?
  fornecedorPrincipal String?
  tipoPrecificacao    String     @default("peso_proporcional")
  status              String     @default("ativo")
  observacoes         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  variacoes  Variacao[]
  compras    Compra[]
}

// ─── VARIAÇÕES ───────────────────────────────────────────────
model Variacao {
  id              String   @id @default(cuid())
  skuVariacao     String   @unique
  skuPrincipal    String
  produto         Produto  @relation(fields: [skuPrincipal], references: [skuPrincipal], onDelete: Cascade)
  nomeVariacao    String
  pesoGramas      Float?
  fatorConversao  Float?
  custoCalculado  Float?
  custoAdicional  Float    @default(0)
  custoTotal      Float?
  embalagem       String?
  status          String   @default("ativo")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  anuncios      Anuncio[]
  precificacoes Precificacao[]
}

// ─── ANÚNCIOS ────────────────────────────────────────────────
// Cada variação pode ter múltiplos anúncios (FULL, Clássico, Shopee, etc.)
model Anuncio {
  id                String   @id @default(cuid())
  skuVariacao       String
  variacao          Variacao @relation(fields: [skuVariacao], references: [skuVariacao], onDelete: Cascade)

  // Identificação
  canal             String   // ml_full | ml_classico | ml_flex | shopee | tray | loja
  codigoAnuncio     String?  // ex: MLB6620253832
  codigoCatalogo    String?  // ex: MLB4562038243 (quando sincronizado)
  skuCanal          String?  // SKU específico do canal (ex: VS000592)
  nomeAnuncio       String?  // nome do anúncio no marketplace

  // Status
  ativo             Boolean  @default(true)

  // Custos específicos deste anúncio
  custoEmbalagem    Float    @default(0)   // 0 para FULL (embalagem deles)
  custoColeta       Float    @default(0.60) // R$0,60/un para FULL
  custoFrete        Float    @default(0)   // calculado pela tabela ou fixo
  tipoFrete         String   @default("full") // full | flex | classico | fixo

  // Comissão e imposto (podem variar por produto/canal)
  comissaoPct       Float
  impostoPct        Float    @default(0.0829)

  // Preço praticado
  precoAtual        Float?

  // Calculados
  custoTotalCalc    Float?
  lucroBruto        Float?
  margemAtual       Float?
  precoMinimo       Float?
  precoIdeal        Float?
  precoMaximo       Float?
  precoPromocional  Float?
  statusMargem      String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── PLATAFORMAS ─────────────────────────────────────────────
model Plataforma {
  id              String   @id @default(cuid())
  nome            String   @unique
  slug            String   @unique
  comissaoPct     Float
  taxaFixa        Float    @default(0)
  custoFrete      Float    @default(0)
  custoColeta     Float    @default(0)
  impostoPct      Float    @default(0.0829)
  corHex          String   @default("#64748b")
  ativa           Boolean  @default(true)
  observacoes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  precificacoes Precificacao[]
}

// ─── PRECIFICAÇÃO (legacy — mantido para compatibilidade) ────
model Precificacao {
  id               String     @id @default(cuid())
  skuVariacao      String
  variacao         Variacao   @relation(fields: [skuVariacao], references: [skuVariacao], onDelete: Cascade)
  plataformaId     String
  plataforma       Plataforma @relation(fields: [plataformaId], references: [id], onDelete: Cascade)
  custoEmbalagem   Float      @default(0)
  custoFrete       Float      @default(0)
  custoColeta      Float      @default(0)
  comissaoPct      Float
  impostoPct       Float      @default(0.0829)
  tipoFreteML      String     @default("full")
  precoAtual       Float?
  custoTotalCalc   Float?
  lucroBruto       Float?
  margemAtual      Float?
  precoMinimo      Float?
  precoIdeal       Float?
  precoMaximo      Float?
  precoPromocional Float?
  statusMargem     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([skuVariacao, plataformaId])
}

// ─── COMPRAS ─────────────────────────────────────────────────
model Compra {
  id               String   @id @default(cuid())
  dataCompra       DateTime
  skuPrincipal     String
  produto          Produto  @relation(fields: [skuPrincipal], references: [skuPrincipal], onDelete: Cascade)
  nomeProduto      String
  fornecedor       String   @default("")
  quantidade       Float
  custoTotal       Float
  frete            Float    @default(0)
  outrosCustos     Float    @default(0)
  custoUnitario    Float
  custoAnterior    Float?
  variacaoPct      Float?
  statusVariacao   String?
  precoVenda       Float?
  impostoPct       Float    @default(0.0829)
  margem           Float?
  statusFinanceiro String?
  fonte            String   @default("manual")
  createdAt        DateTime @default(now())
}

// ─── FORNECEDORES ────────────────────────────────────────────
model Fornecedor {
  id        String   @id @default(cuid())
  nome      String   @unique
  contato   String?
  obs       String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── CONFIGURAÇÕES (imposto mensal, parâmetros globais) ──────
model Configuracao {
  id        String   @id @default(cuid())
  chave     String   @unique  // ex: imposto_2026_05
  valor     String            // ex: "0.0829"
  descricao String?
  updatedAt DateTime @updatedAt
}

// ─── FATURAMENTO DIÁRIO ──────────────────────────────────────
model Faturamento {
  id             String   @id @default(cuid())
  data           DateTime
  canal          String   // ml_full | ml_classico | shopee | tray | loja
  faturamentoBruto Float
  nrPedidos      Int      @default(0)
  impostoPct     Float    @default(0.0829)
  impostoValor   Float?
  faturamentoLiq Float?
  obs            String?
  createdAt      DateTime @default(now())

  @@unique([data, canal])
}
