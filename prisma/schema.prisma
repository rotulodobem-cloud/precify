generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PRODUTOS ────────────────────────────────────────────────
model Produto {
  id                  String     @id @default(cuid())
  skuPrincipal        String     @unique
  nome                String
  categoria           String     @default("Geral")
  unidadeCompra       String     @default("kg")
  custoPorKg          Float?
  custoUnitario       Float?
  custoAtualizado     Float?
  dataUltimaCompra    DateTime?
  fornecedorPrincipal String?
  tipoPrecificacao    String     @default("peso_proporcional")
  status              String     @default("ativo")
  observacoes         String?
  categoriaML         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  variacoes  Variacao[]
  aliases    FornecedorAlias[]
  compras    Compra[]
}

// ─── VARIAÇÕES ───────────────────────────────────────────────
model Variacao {
  id              String   @id @default(cuid())
  skuVariacao     String   @unique
  skuPrincipal    String
  produto         Produto  @relation(fields: [skuPrincipal], references: [skuPrincipal], onDelete: Cascade)
  nomeVariacao    String
  pesoGramas      Float?
  fatorConversao  Float?
  custoCalculado  Float?
  custoAdicional  Float    @default(0)
  custoTotal      Float?
  embalagem          String?
  usaSacoCoextrusado Boolean  @default(false)
  status             String   @default("ativo")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── PLATAFORMAS ─────────────────────────────────────────────
model Plataforma {
  id              String   @id @default(cuid())
  nome            String   @unique
  slug            String   @unique
  comissaoPct     Float
  taxaFixa        Float    @default(0)
  custoFrete      Float    @default(0)
  custoColeta     Float    @default(0)
  custoEmbalagem  Float    @default(0)
  impostoPct      Float    @default(0.0829)
  corHex          String   @default("#64748b")
  ativa           Boolean  @default(true)
  observacoes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── COMPRAS ─────────────────────────────────────────────────
model Compra {
  id               String   @id @default(cuid())
  dataCompra       DateTime
  skuPrincipal     String
  produto          Produto  @relation(fields: [skuPrincipal], references: [skuPrincipal], onDelete: Cascade)
  nomeProduto      String
  fornecedor       String   @default("")
  quantidade       Float
  custoTotal       Float
  frete            Float    @default(0)
  outrosCustos     Float    @default(0)
  custoUnitario    Float
  custoAnterior    Float?
  variacaoPct      Float?
  statusVariacao   String?
  precoVenda       Float?
  impostoPct       Float    @default(0.0829)
  margem           Float?
  statusFinanceiro String?
  fonte            String   @default("manual")
  numeroNF         String?
  numeroPedido     String?
  createdAt        DateTime @default(now())

  lotes            Lote[]
}

// ─── LOTES (rastreabilidade / vigilância sanitária) ───────────
model Lote {
  id            String    @id @default(cuid())
  compraId      String
  compra        Compra    @relation(fields: [compraId], references: [id], onDelete: Cascade)
  numeroLote    String
  geradoAuto    Boolean   @default(false)
  quantidade    Float
  dataValidade  DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([numeroLote])
  @@index([compraId])
}

// ─── FORNECEDORES ────────────────────────────────────────────
model Fornecedor {
  id        String   @id @default(cuid())
  nome      String   @unique
  contato   String?
  obs       String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── CONFIGURAÇÕES (imposto mensal, parâmetros globais) ──────
model Configuracao {
  id        String   @id @default(cuid())
  chave     String   @unique  // ex: imposto_2026_05
  valor     String            // ex: "0.0829"
  descricao String?
  updatedAt DateTime @updatedAt
}

// ─── KITS ────────────────────────────────────────────────────
model Kit {
  id              String         @id @default(cuid())
  skuKit          String         @unique  // ex: KIT0045
  nome            String
  categoria       String         @default("Kits")
  custoTotal      Float?         // calculado automaticamente pela soma dos componentes
  custoEmbalagem  Float          @default(0)
  observacoes     String?
  status          String         @default("ativo")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  componentes     KitComponente[]
}

model KitComponente {
  id              String   @id @default(cuid())
  kitId           String
  kit             Kit      @relation(fields: [kitId], references: [id], onDelete: Cascade)
  skuProduto      String   // SKU do produto componente
  nomeProduto     String   // nome snapshot para exibição
  quantidadeGramas Float?  // em gramas (para produtos por kg)
  quantidadeUn    Float?   // em unidades (para produtos por unidade)
  custoUnitario   Float    // custo calculado deste componente no momento do cadastro
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── FATURAMENTO DIÁRIO ──────────────────────────────────────
model Faturamento {
  id             String   @id @default(cuid())
  data           DateTime
  canal          String   // ml_full | ml_classico | shopee | tray | loja
  faturamentoBruto Float
  nrPedidos      Int      @default(0)
  impostoPct     Float    @default(0.0829)
  impostoValor   Float?
  faturamentoLiq Float?
  obs            String?
  createdAt      DateTime @default(now())

  @@unique([data, canal])
}

// --- ALIAS DE PRODUTO POR FORNECEDOR -----------------------------------------
model FornecedorAlias {
  id               String   @id @default(cuid())
  skuPrincipal     String
  produto          Produto  @relation(fields: [skuPrincipal], references: [skuPrincipal], onDelete: Cascade)
  fornecedor       String
  nomeNoFornecedor String
  codigoFornecedor String?
  embalagem        String?
  ultimoPreco      Float?
  dataUltimoPreco  DateTime?
  ativo            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@unique([fornecedor, nomeNoFornecedor])
  @@index([skuPrincipal])
  @@index([fornecedor])
}

// --- PEDIDO DE COMPRA --------------------------------------------
model PedidoCompra {
  id         String       @id @default(cuid())
  fornecedor String
  status     String       @default("rascunho")
  obs        String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  itens      PedidoItem[]
}

model PedidoItem {
  id               String       @id @default(cuid())
  pedidoId         String
  pedido           PedidoCompra @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  skuPrincipal     String
  nomeProduto      String
  nomeNoFornecedor String?
  codigoFornecedor String?
  quantidade       Float
  unidade          String   @default("kg")
  precoUnitario    Float?
  obs              String?
  createdAt        DateTime @default(now())
}

// ─── PRECIFICAÇÃO MULTICANAL (Rótulo do Bem) ──────────────────
// Independente de Precificacao/Plataforma: guarda os 5 canais
// (Loja Própria, ML Full, ML Clássico, Shopee, TikTok Shop) lado
// a lado por SKU+Variação, o que o model Precificacao não permite
// (lá só cabe 1 linha por SKU×Plataforma).
model CalculoMulticanal {
  id                            String    @id @default(cuid())
  skuVariacao                   String?
  sku                           String?
  nome                          String
  variacao                      String    @default("")
  custoProduto                  Float
  pesoGramas                    Float?
  despesasVariaveisPct          Float     @default(8)
  despesasFixasPct              Float     @default(0)
  modo                          String    @default("preco")
  precoTeste                    Float?
  canais                        Json
  codigosAnuncio                Json?
  canaisAtivos                  Json?
  precoPraticadoLP              Float?
  precoPraticadoLPAtualizadoEm  DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  @@unique([sku, variacao])
}
